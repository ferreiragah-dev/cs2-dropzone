# ─── DROPZONE CONFIG ───────────────────────────────────────────────
# 1. Obtenha sua Steam API Key em: https://steamcommunity.com/dev/apikey
# 2. Preencha abaixo e salve como .env

STEAM_API_KEY=89DD291A64565E028593244197356B5A

# URL base da sua aplicação (ex: http://localhost:3000)
