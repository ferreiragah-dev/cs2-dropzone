# ──────────────────────────────────────────────
#  DROPZONE — Configuração
# ──────────────────────────────────────────────

# 1. Crie sua chave gratuita em:
#    https://steamcommunity.com/dev/apikey
#    (coloque "localhost" no campo Domínio)
STEAM_API_KEY=COLE_SUA_CHAVE_AQUI

# 2. URL base do servidor (não mude para testes locais)
BASE_URL=http://localhost:3000

# 3. Segredo da sessão — qualquer texto longo aleatorio
SESSION_SECRET=mude_isso_para_algo_secreto_longo_123456

# 4. Porta
PORT=3000
